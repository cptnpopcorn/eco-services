server {
	listen 443 ssl;
	server_name ${BAMPREFIX}.${DOMAIN};

	ssl_certificate /etc/letsencrypt/live/${BAMPREFIX}.${DOMAIN}/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/${BAMPREFIX}.${DOMAIN}/privkey.pem;

	root /var/www/bam;
	index index.html index.htm;

	location / {
		try_files $uri $uri/ =404;
	}
}

server {
	listen 80;
	server_name ${BAMPREFIX}.${DOMAIN};
	return 301 https://$server_name$request_uri;
}
